# ===========================================
# SEO Marketing CRM - Environment Variables
# ===========================================
# IMPORTANT: Copy this file to .env and fill in your actual values
# NEVER commit .env file to git repository!
# ===========================================

# Prisma Database
DATABASE_URL="file:./dev.db"

# Looker Studio Embed URLs (Update with your actual URLs)
NEXT_PUBLIC_LOOKER_GA4_URL="https://lookerstudio.google.com/embed/reporting/YOUR_GA4_REPORT_ID"
NEXT_PUBLIC_LOOKER_GSC_URL="https://lookerstudio.google.com/embed/reporting/YOUR_GSC_REPORT_ID"

# Google Apps Script Web App URL
GOOGLE_APPS_SCRIPT_URL="https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec"

# Google Search Console - Site URL
GOOGLE_SEARCH_CONSOLE_SITE_URL="https://your-site.com/"

# AI Citation Monitoring
# Get your Perplexity API key from: https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY="pplx-xxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# Cron job security (optional - set a random string for production)
CRON_SECRET="your-secret-key-here"

# Slack API Integration (for KPI conversion tracking)
# 1. Create a Slack App: https://api.slack.com/apps
# 2. Add Bot Token Scopes: channels:history, channels:read
# 3. Install to workspace and copy the Bot User OAuth Token
SLACK_BOT_TOKEN="xoxb-xxxxxxxxxxxx-xxxxxxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxx"

# Slack Channel IDs (right-click channel > View channel details > scroll to bottom)
SLACK_DEMO_CHANNEL_ID="C0XXXXXXXXX"       # #07_デモ依頼
SLACK_INQUIRY_CHANNEL_ID="C0XXXXXXXXX"    # #08_お問い合わせ

# Pipedrive API Integration
# 1. Login to Pipedrive
# 2. Go to Settings → Personal preferences → API
# 3. Copy your personal API token
PIPEDRIVE_API_TOKEN="your-pipedrive-api-token-here"

# ===========================================
# BLOCKED SERVICES - DO NOT USE
# ===========================================
# Supabase is STRICTLY PROHIBITED in this project.
# Any Supabase-related configurations will be blocked.
#
# The following are NOT allowed:
# - SUPABASE_URL
# - SUPABASE_ANON_KEY
# - SUPABASE_SERVICE_ROLE_KEY
# - NEXT_PUBLIC_SUPABASE_URL
# - NEXT_PUBLIC_SUPABASE_ANON_KEY
# - Any @supabase packages
# ===========================================
